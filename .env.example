PORT=8080
API_KEY=test-key
LOG_LEVEL=debug
RATE_LIMIT=10
RATE_BURST=20
FALLBACK_MODELS=llama3.2,phi3
# Redis — required for multi-instance (K8s) deployments.
# Backs response cache, distributed rate limiting, and usage tracking.
# If empty, all three fall back to in-memory (single-instance only).
REDIS_URL=redis://redis:6379
CACHE_TTL=5m
OTEL_EXPORTER_OTLP_ENDPOINT=otel-collector:4317

# --- Provider Configuration ---
# Option 1: Use env vars (backwards compatible)
OLLAMA_URL=http://ollama:11434
OLLAMA_MODELS=llama3.2,phi3,mistral

# Option 2: OpenAI (set OPENAI_API_KEY to enable)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com
# OPENAI_MODELS=gpt-4o,gpt-4o-mini

# Option 3: Anthropic (set ANTHROPIC_API_KEY to enable)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_MODELS=claude-sonnet-4-20250514,claude-haiku-4-20250506

# Option 4: JSON config file (overrides env-based config)
# PROVIDERS_CONFIG=providers.json
